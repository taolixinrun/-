<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes">
  <title>无言·桃李 | 法学保研追踪系统</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', 'Roboto', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    }

    body {
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      min-height: 100vh;
      padding: 1rem;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
    }

    /* 优雅的头部设计 */
    .header {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      padding: 1.5rem 2rem;
      border-radius: 20px;
      margin-bottom: 1.5rem;
      box-shadow: 0 8px 32px rgba(31, 38, 135, 0.1);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .brand i {
      font-size: 2.5rem;
      color: #2d3748;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .brand h1 {
      font-size: 2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 2px;
    }

    .brand span {
      font-size: 0.9rem;
      color: #718096;
      font-style: italic;
    }

    .monitor-status {
      display: flex;
      align-items: center;
      gap: 1rem;
      background: #edf2f7;
      padding: 0.8rem 1.5rem;
      border-radius: 50px;
    }

    .status-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #48bb78;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0% { opacity: 1; }
      50% { opacity: 0.5; }
      100% { opacity: 1; }
    }

    /* 导航标签 */
    .nav-tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      background: rgba(255, 255, 255, 0.9);
      padding: 0.5rem;
      border-radius: 50px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      overflow-x: auto;
    }

    .tab {
      padding: 0.8rem 1.8rem;
      border-radius: 50px;
      border: none;
      background: transparent;
      cursor: pointer;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.3s;
      white-space: nowrap;
      color: #4a5568;
    }

    .tab.active {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
    }

    .tab:hover:not(.active) {
      background: #e2e8f0;
    }

    /* 面板容器 */
    .panel {
      display: none;
      animation: fadeIn 0.4s ease;
    }

    .panel.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* 项目卡片 */
    .project-card {
      background: white;
      border-radius: 20px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      box-shadow: 0 10px 40px rgba(0,0,0,0.08);
      border-left: 4px solid #667eea;
      transition: all 0.3s;
    }

    .project-card:hover {
      box-shadow: 0 15px 50px rgba(0,0,0,0.12);
      transform: translateY(-2px);
    }

    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .project-title {
      font-size: 1.3rem;
      font-weight: 700;
      color: #2d3748;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    /* 时间线表格 */
    .timeline-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .time-field {
      background: #f7fafc;
      padding: 0.8rem;
      border-radius: 12px;
      text-align: center;
    }

    .time-field label {
      display: block;
      font-size: 0.8rem;
      color: #718096;
      margin-bottom: 0.3rem;
      font-weight: 600;
    }

    .time-field input {
      border: 2px solid #e2e8f0;
      border-radius: 8px;
      padding: 0.4rem;
      width: 100%;
      font-size: 0.85rem;
      text-align: center;
    }

    /* 材料清单 */
    .materials-section {
      background: #f7fafc;
      padding: 1rem;
      border-radius: 12px;
      margin-bottom: 1rem;
    }

    .material-item {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid #e2e8f0;
    }

    .material-item:last-child {
      border-bottom: none;
    }

    /* 进度条 */
    .progress-stages {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      margin: 1rem 0;
      flex-wrap: wrap;
    }

    .stage {
      padding: 0.4rem 1rem;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
      background: #edf2f7;
      color: #a0aec0;
    }

    .stage.completed {
      background: #48bb78;
      color: white;
    }

    .stage.failed {
      background: #fc8181;
      color: white;
    }

    .stage.current {
      background: #667eea;
      color: white;
    }

    /* 按钮样式 */
    .btn {
      padding: 0.6rem 1.2rem;
      border-radius: 25px;
      border: none;
      cursor: pointer;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
    }

    .btn-danger {
      background: #fc8181;
      color: white;
    }

    .btn-success {
      background: #48bb78;
      color: white;
    }

    .btn-sm {
      padding: 0.3rem 0.8rem;
      font-size: 0.8rem;
    }

    /* 监控面板 */
    .monitor-panel {
      background: white;
      border-radius: 20px;
      padding: 1.5rem;
      box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    }

    .news-item {
      padding: 1rem;
      border-left: 3px solid #667eea;
      margin-bottom: 1rem;
      background: #f7fafc;
      border-radius: 0 12px 12px 0;
    }

    .news-item.new {
      animation: highlight 2s ease;
    }

    @keyframes highlight {
      0% { background: #fef5e7; }
      100% { background: #f7fafc; }
    }

    /* 响应式 */
    @media (max-width: 768px) {
      .header {
        flex-direction: column;
        text-align: center;
      }
      
      .timeline-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      
      .nav-tabs {
        flex-wrap: nowrap;
        overflow-x: auto;
      }
    }
  </style>
</head>
<body>
<div class="container">
  <!-- 头部 -->
  <div class="header">
    <div class="brand">
      <i class="fas fa-feather-alt"></i>
      <div>
        <h1>无言·桃李</h1>
        <span>法学保研追踪系统</span>
      </div>
    </div>
    <div class="monitor-status">
      <div class="status-dot"></div>
      <span>智能监控中 · 985高校法学院</span>
      <small id="lastUpdate">刚刚更新</small>
    </div>
  </div>

  <!-- 导航 -->
  <div class="nav-tabs">
    <button class="tab active" data-panel="summer"><i class="fas fa-sun"></i> 夏令营</button>
    <button class="tab" data-panel="pre"><i class="fas fa-leaf"></i> 预推免</button>
    <button class="tab" data-panel="offers"><i class="fas fa-gift"></i> Offer接收</button>
    <button class="tab" data-panel="confirm"><i class="fas fa-star"></i> Offer确认</button>
    <button class="tab" data-panel="monitor"><i class="fas fa-satellite"></i> 智能监控</button>
  </div>

  <!-- 夏令营面板 -->
  <div id="summerPanel" class="panel active">
    <div id="summerProjects"></div>
    <button class="btn btn-primary" onclick="addProject('summer')" style="margin-top: 1rem;">
      <i class="fas fa-plus"></i> 新建夏令营项目
    </button>
  </div>

  <!-- 预推免面板 -->
  <div id="prePanel" class="panel">
    <div id="preProjects"></div>
    <button class="btn btn-primary" onclick="addProject('pre')" style="margin-top: 1rem;">
      <i class="fas fa-plus"></i> 新建预推免项目
    </button>
  </div>

  <!-- Offer接收面板 -->
  <div id="offersPanel" class="panel">
    <div id="offersList"></div>
  </div>

  <!-- Offer确认面板 -->
  <div id="confirmPanel" class="panel">
    <div id="confirmContent"></div>
  </div>

  <!-- 智能监控面板 -->
  <div id="monitorPanel" class="panel">
    <div class="monitor-panel">
      <h2 style="margin-bottom: 1rem;"><i class="fas fa-robot"></i> 985高校法学院监控中心</h2>
      <p style="color: #718096; margin-bottom: 1.5rem;">
        实时监控39所985高校法学院官网、微信公众号及保研论坛信息
      </p>
      <div id="monitorNews"></div>
    </div>
  </div>
</div>

<script>
  (function() {
    // 法学专业代码
    const LAW_CODES = {
      '0301': '法学',
      '030101': '法学理论',
      '030102': '法律史',
      '030103': '宪法学与行政法学',
      '030104': '刑法学',
      '030105': '民商法学',
      '030106': '诉讼法学',
      '030107': '经济法学',
      '030108': '环境与资源保护法学',
      '030109': '国际法学'
    };

    // 985高校列表（部分法学院强校）
    const LAW_SCHOOLS_985 = [
      '北京大学', '清华大学', '中国人民大学', '复旦大学', '上海交通大学',
      '浙江大学', '南京大学', '武汉大学', '厦门大学', '中山大学',
      '吉林大学', '山东大学', '四川大学', '南开大学', '同济大学',
      '北京师范大学', '华东师范大学', '华中科技大学', '西安交通大学',
      '兰州大学', '中国海洋大学', '西北工业大学', '中央民族大学',
      '北京理工大学', '北京航空航天大学', '中国农业大学', '东南大学',
      '中南大学', '大连理工大学', '东北大学', '重庆大学',
      '湖南大学', '华南理工大学', '电子科技大学', '西北农林科技大学'
    ];

    // 数据结构
    let appData = {
      summerProjects: [],  // {id, school, deadlines:{apply, notice, campStart, campEnd, result}, materials:[], result:null}
      preProjects: [],     // {id, school, deadlines:{apply, notice, interview, result}, materials:[], result:null}
      offers: [],          // {id, school, major, code, source} - source: 'summer' or 'pre'
      confirmedOffer: null,
      lastMonitorUpdate: new Date().toISOString()
    };

    // 初始化数据
    function initData() {
      const saved = localStorage.getItem('wuyantaoli_data');
      if (saved) {
        try {
          appData = JSON.parse(saved);
        } catch(e) {
          initDefaultData();
        }
      } else {
        initDefaultData();
      }
    }

    function initDefaultData() {
      // 默认添加武汉大学国际法研究所作为已有offer
      appData.offers.push({
        id: 'default_whu',
        school: '武汉大学',
        major: '国际法学',
        code: '030109',
        source: 'pre'
      });
      appData.confirmedOffer = 'default_whu';
      saveData();
    }

    function saveData() {
      localStorage.setItem('wuyantaoli_data', JSON.stringify(appData));
    }

    // 创建新项目
    window.addProject = function(type) {
      const school = prompt('请输入学校名称（如：西安交通大学）：');
      if (!school) return;
      
      const project = {
        id: Date.now().toString(),
        school: school,
        deadlines: type === 'summer' ? {
          apply: '',      // 申报时间
          notice: '',     // 通知时间
          campStart: '',  // 夏令营开始
          campEnd: '',    // 夏令营结束
          result: ''      // 结果公布
        } : {
          apply: '',      // 申报时间
          notice: '',     // 通知时间
          interview: '',  // 复试时间
          result: ''      // 结果公布
        },
        materials: [],
        result: null,     // {status, stage}
        notes: ''
      };
      
      if (type === 'summer') {
        appData.summerProjects.push(project);
      } else {
        appData.preProjects.push(project);
      }
      
      saveData();
      renderAll();
    };

    // 添加材料项
    window.addMaterial = function(projectId, type) {
      const name = prompt('材料名称（如：个人陈述、推荐信等）：');
      if (!name) return;
      
      const projects = type === 'summer' ? appData.summerProjects : appData.preProjects;
      const project = projects.find(p => p.id === projectId);
      if (project) {
        project.materials.push({ id: Date.now().toString(), name, done: false });
        saveData();
        renderAll();
      }
    };

    // 切换材料状态
    window.toggleMaterial = function(projectId, materialId, type, checked) {
      const projects = type === 'summer' ? appData.summerProjects : appData.preProjects;
      const project = projects.find(p => p.id === projectId);
      if (project) {
        const material = project.materials.find(m => m.id === materialId);
        if (material) {
          material.done = checked;
          saveData();
        }
      }
    };

    // 设置结果
    window.setResult = function(projectId, type) {
      const projects = type === 'summer' ? appData.summerProjects : appData.preProjects;
      const project = projects.find(p => p.id === projectId);
      if (!project) return;
      
      const statusOptions = type === 'summer' ? 
        ['未通过', '入营未获优营', '普通营员', '优秀营员'] :
        ['未通过', '等待复试', '复试通过', '获得Offer'];
      
      const status = prompt(`选择结果状态：\n${statusOptions.join('\n')}`, statusOptions[statusOptions.length-1]);
      if (!status) return;
      
      project.result = {
        status: status,
        date: new Date().toISOString().split('T')[0]
      };
      
      // 如果是预推免获得Offer，自动添加到offer列表
      if (type === 'pre' && status === '获得Offer') {
        const major = prompt('请输入专业名称（如：国际法学）：', '法学');
        const code = prompt('请输入专业代码（如：030109）：', '0301');
        
        const existingOffer = appData.offers.find(o => 
          o.school === project.school && o.major === major
        );
        
        if (!existingOffer) {
          appData.offers.push({
            id: Date.now().toString(),
            school: project.school,
            major: major,
            code: code,
            source: 'pre'
          });
          alert(`✅ 已自动将 ${project.school} ${major} 添加到Offer接收板块`);
        }
      }
      
      saveData();
      renderAll();
    };

    // 删除项目
    window.deleteProject = function(projectId, type) {
      if (!confirm('确定删除此项目吗？')) return;
      
      if (type === 'summer') {
        appData.summerProjects = appData.summerProjects.filter(p => p.id !== projectId);
      } else {
        appData.preProjects = appData.preProjects.filter(p => p.id !== projectId);
      }
      
      saveData();
      renderAll();
    };

    // 更新截止日期
    window.updateDeadline = function(projectId, field, value, type) {
      const projects = type === 'summer' ? appData.summerProjects : appData.preProjects;
      const project = projects.find(p => p.id === projectId);
      if (project) {
        project.deadlines[field] = value;
        saveData();
      }
    };

    // 确认Offer
    window.confirmOffer = function(offerId) {
      appData.confirmedOffer = offerId;
      saveData();
      renderAll();
    };

    // 删除Offer
    window.deleteOffer = function(offerId) {
      if (!confirm('确定删除此Offer吗？')) return;
      appData.offers = appData.offers.filter(o => o.id !== offerId);
      if (appData.confirmedOffer === offerId) {
        appData.confirmedOffer = null;
      }
      saveData();
      renderAll();
    };

    // 渲染所有面板
    function renderAll() {
      renderSummerProjects();
      renderPreProjects();
      renderOffers();
      renderConfirm();
      renderMonitor();
    }

    // 渲染夏令营项目
    function renderSummerProjects() {
      const container = document.getElementById('summerProjects');
      if (!container) return;
      
      if (appData.summerProjects.length === 0) {
        container.innerHTML = '<p style="color:#718096; text-align:center; padding:2rem;">暂无夏令营项目，点击下方按钮创建</p>';
        return;
      }
      
      container.innerHTML = appData.summerProjects.map(project => `
        <div class="project-card">
          <div class="project-header">
            <div class="project-title">
              <i class="fas fa-university"></i>
              ${project.school} · 夏令营
            </div>
            <button class="btn btn-danger btn-sm" onclick="deleteProject('${project.id}', 'summer')">
              <i class="fas fa-trash"></i> 删除
            </button>
          </div>
          
          <div class="timeline-grid">
            <div class="time-field">
              <label>申报时间</label>
              <input type="date" value="${project.deadlines.apply || ''}" 
                onchange="updateDeadline('${project.id}', 'apply', this.value, 'summer')">
            </div>
            <div class="time-field">
              <label>通知时间</label>
              <input type="date" value="${project.deadlines.notice || ''}" 
                onchange="updateDeadline('${project.id}', 'notice', this.value, 'summer')">
            </div>
            <div class="time-field">
              <label>夏令营开始</label>
              <input type="date" value="${project.deadlines.campStart || ''}" 
                onchange="updateDeadline('${project.id}', 'campStart', this.value, 'summer')">
            </div>
            <div class="time-field">
              <label>夏令营结束</label>
              <input type="date" value="${project.deadlines.campEnd || ''}" 
                onchange="updateDeadline('${project.id}', 'campEnd', this.value, 'summer')">
            </div>
            <div class="time-field">
              <label>结果公布</label>
              <input type="date" value="${project.deadlines.result || ''}" 
                onchange="updateDeadline('${project.id}', 'result', this.value, 'summer')">
            </div>
          </div>
          
          <div class="materials-section">
            <h4 style="margin-bottom:0.5rem;"><i class="fas fa-clipboard-list"></i> 申请材料</h4>
            ${project.materials.map(m => `
              <div class="material-item">
                <input type="checkbox" ${m.done ? 'checked' : ''} 
                  onchange="toggleMaterial('${project.id}', '${m.id}', 'summer', this.checked)">
                <span style="${m.done ? 'text-decoration:line-through; color:#a0aec0;' : ''}">${m.name}</span>
                <button class="btn btn-sm" onclick="deleteMaterial('${project.id}', '${m.id}', 'summer')">
                  <i class="fas fa-times"></i>
                </button>
              </div>
            `).join('')}
            <button class="btn btn-sm btn-primary" onclick="addMaterial('${project.id}', 'summer')" style="margin-top:0.5rem;">
              <i class="fas fa-plus"></i> 添加材料
            </button>
          </div>
          
          <div style="margin-top:1rem;">
            <h4 style="margin-bottom:0.5rem;"><i class="fas fa-flag"></i> 结果与进度</h4>
            ${project.result ? `
              <div class="progress-stages">
                ${renderProgressStages('summer', project.result.status)}
              </div>
              <p style="color:#718096; font-size:0.9rem;">状态：${project.result.status} | 日期：${project.result.date}</p>
            ` : '<p style="color:#a0aec0;">尚未设置结果</p>'}
            <button class="btn btn-sm btn-primary" onclick="setResult('${project.id}', 'summer')">
              <i class="fas fa-edit"></i> 设置结果
            </button>
          </div>
          
          <div style="margin-top:1rem;">
            <label>备注：</label>
            <textarea rows="2" style="width:100%; border-radius:8px; border:1px solid #e2e8f0; padding:0.5rem;" 
              onchange="updateNotes('${project.id}', 'summer', this.value)">${project.notes || ''}</textarea>
          </div>
        </div>
      `).join('');
    }

    // 渲染预推免项目
    function renderPreProjects() {
      const container = document.getElementById('preProjects');
      if (!container) return;
      
      if (appData.preProjects.length === 0) {
        container.innerHTML = '<p style="color:#718096; text-align:center; padding:2rem;">暂无预推免项目，点击下方按钮创建</p>';
        return;
      }
      
      container.innerHTML = appData.preProjects.map(project => `
        <div class="project-card" style="border-left-color: #48bb78;">
          <div class="project-header">
            <div class="project-title">
              <i class="fas fa-university"></i>
              ${project.school} · 预推免
            </div>
            <button class="btn btn-danger btn-sm" onclick="deleteProject('${project.id}', 'pre')">
              <i class="fas fa-trash"></i> 删除
            </button>
          </div>
          
          <div class="timeline-grid">
            <div class="time-field">
              <label>申报时间</label>
              <input type="date" value="${project.deadlines.apply || ''}" 
                onchange="updateDeadline('${project.id}', 'apply', this.value, 'pre')">
            </div>
            <div class="time-field">
              <label>通知时间</label>
              <input type="date" value="${project.deadlines.notice || ''}" 
                onchange="updateDeadline('${project.id}', 'notice', this.value, 'pre')">
            </div>
            <div class="time-field">
              <label>复试时间</label>
              <input type="date" value="${project.deadlines.interview || ''}" 
                onchange="updateDeadline('${project.id}', 'interview', this.value, 'pre')">
            </div>
            <div class="time-field">
              <label>结果公布</label>
              <input type="date" value="${project.deadlines.result || ''}" 
                onchange="updateDeadline('${project.id}', 'result', this.value, 'pre')">
            </div>
          </div>
          
          <div class="materials-section">
            <h4 style="margin-bottom:0.5rem;"><i class="fas fa-clipboard-list"></i> 申请材料</h4>
            ${project.materials.map(m => `
              <div class="material-item">
                <input type="checkbox" ${m.done ? 'checked' : ''} 
                  onchange="toggleMaterial('${project.id}', '${m.id}', 'pre', this.checked)">
                <span style="${m.done ? 'text-decoration:line-through; color:#a0aec0;' : ''}">${m.name}</span>
                <button class="btn btn-sm" onclick="deleteMaterial('${project.id}', '${m.id}', 'pre')">
                  <i class="fas fa-times"></i>
                </button>
              </div>
            `).join('')}
            <button class="btn btn-sm btn-primary" onclick="addMaterial('${project.id}', 'pre')" style="margin-top:0.5rem;">
              <i class="fas fa-plus"></i> 添加材料
            </button>
          </div>
          
          <div style="margin-top:1rem;">
            <h4 style="margin-bottom:0.5rem;"><i class="fas fa-flag"></i> 结果与进度</h4>
            ${project.result ? `
              <div class="progress-stages">
                ${renderProgressStages('pre', project.result.status)}
              </div>
              <p style="color:#718096; font-size:0.9rem;">状态：${project.result.status} | 日期：${project.result.date}</p>
            ` : '<p style="color:#a0aec0;">尚未设置结果</p>'}
            <button class="btn btn-sm btn-primary" onclick="setResult('${project.id}', 'pre')">
              <i class="fas fa-edit"></i> 设置结果
            </button>
          </div>
        </div>
      `).join('');
    }

    // 渲染进度条
    function renderProgressStages(type, status) {
      if (type === 'summer') {
        const stages = ['申请', '入营', '参营', '考核'];
        const finalStage = status.includes('优秀营员') ? '优秀营员' : 
                          status.includes('普通营员') ? '普通营员' :
                          status.includes('未通过') ? '未通过' : '等待结果';
        
        let stagesHtml = stages.map(stage => {
          let cls = '';
          if (status === '未通过') cls = 'failed';
          else if (finalStage === '优秀营员' || finalStage === '普通营员') cls = 'completed';
          else if (stage === stages[stages.length-1]) cls = 'current';
          return `<span class="stage ${cls}">${stage}</span>`;
        }).join('<i class="fas fa-arrow-right" style="color:#cbd5e0;"></i>');
        
        stagesHtml += `<i class="fas fa-arrow-right" style="color:#cbd5e0;"></i>`;
        stagesHtml += `<span class="stage ${finalStage === '优秀营员' ? 'completed' : finalStage === '未通过' ? 'failed' : 'current'}">${finalStage}</span>`;
        
        return stagesHtml;
      } else {
        const stages = ['申请', '通知', '复试', '结果'];
        const finalStage = status.includes('获得Offer') ? '获得Offer' :
                          status.includes('复试通过') ? '复试通过' :
                          status.includes('未通过') ? '未通过' : '等待结果';
        
        let stagesHtml = stages.map(stage => {
          let cls = '';
          if (status === '未通过') cls = 'failed';
          else if (finalStage === '获得Offer' || finalStage === '复试通过') cls = 'completed';
          else if (stage === stages[stages.length-1]) cls = 'current';
          return `<span class="stage ${cls}">${stage}</span>`;
        }).join('<i class="fas fa-arrow-right" style="color:#cbd5e0;"></i>');
        
        return stagesHtml;
      }
    }

