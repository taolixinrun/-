<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes">
  <title>保研进度追踪 · 名校夏令营预推免</title>
  <!-- Font Awesome 6 图标库 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', 'Roboto', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    }

    body {
      background: #f4f7fc;
      padding: 1.5rem;
      color: #1e293b;
    }

    .container {
      max-width: 1300px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    /* 头部与校徽装饰 */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      background: white;
      padding: 1.2rem 2rem;
      border-radius: 2rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.04);
    }

    .logo-area {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .logo-icon {
      font-size: 2.5rem;
      color: #0f4c81;
    }

    .title h1 {
      font-weight: 600;
      font-size: 1.8rem;
      letter-spacing: 1px;
      background: linear-gradient(135deg, #0f4c81, #3b82b6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .school-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      align-items: center;
    }

    .badge {
      background: #f1f5f9;
      border-radius: 3rem;
      padding: 0.4rem 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
      font-size: 0.9rem;
      box-shadow: 0 2px 6px rgba(0,0,0,0.02);
      transition: all 0.2s;
    }

    .badge i {
      font-size: 1.2rem;
      color: #0f4c81;
    }

    .badge:hover {
      background: #e2e8f0;
      transform: translateY(-1px);
    }

    /* 选项卡式阶段导航 */
    .phase-tabs {
      display: flex;
      gap: 0.5rem;
      background: white;
      padding: 0.5rem;
      border-radius: 3rem;
      box-shadow: 0 6px 16px rgba(0,0,0,0.03);
      flex-wrap: wrap;
    }

    .tab {
      flex: 1;
      text-align: center;
      padding: 0.8rem 1rem;
      border-radius: 2.5rem;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
      background: transparent;
      color: #475569;
      border: none;
      font-size: 0.95rem;
    }

    .tab i {
      margin-right: 0.4rem;
    }

    .tab.active {
      background: #0f4c81;
      color: white;
      box-shadow: 0 8px 14px rgba(15,76,129,0.25);
    }

    .panel {
      display: none;
      animation: fade 0.25s ease;
    }

    .panel.active {
      display: block;
    }

    @keyframes fade { from { opacity: 0.3; } to { opacity: 1; } }

    /* 卡片设计 */
    .card {
      background: white;
      border-radius: 1.8rem;
      padding: 1.5rem;
      box-shadow: 0 10px 25px rgba(0,0,0,0.04);
      margin-bottom: 1.5rem;
    }

    .section-title {
      font-weight: 650;
      font-size: 1.2rem;
      margin-bottom: 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      border-left: 5px solid #0f4c81;
      padding-left: 1rem;
    }

    .grid-2col {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .ddl-item {
      background: #f8fafc;
      border-radius: 1.2rem;
      padding: 1rem;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .progress-bar-bg {
      background: #e2e8f0;
      height: 10px;
      border-radius: 20px;
      margin-top: 0.5rem;
      width: 100%;
      overflow: hidden;
    }

    .progress-fill {
      height: 10px;
      border-radius: 20px;
      background: #10b981;
      width: 0%;
      transition: width 0.3s;
    }

    .progress-fill.red {
      background: #ef4444;
    }

    .checklist li {
      list-style: none;
      display: flex;
      align-items: center;
      gap: 0.7rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid #f1f5f9;
    }

    .btn {
      background: white;
      border: 1px solid #cbd5e1;
      padding: 0.4rem 1rem;
      border-radius: 2rem;
      cursor: pointer;
      font-size: 0.8rem;
      transition: 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }

    .btn-primary {
      background: #0f4c81;
      border-color: #0f4c81;
      color: white;
    }

    .btn-danger {
      color: #b91c1c;
      border-color: #fecaca;
    }

    select, input, textarea {
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 0.5rem 0.8rem;
      font-size: 0.9rem;
      background: white;
    }

    .offer-card {
      border: 1px solid #e9eef2;
      border-radius: 1.5rem;
      padding: 1rem;
      margin-bottom: 1rem;
    }

    .selected-offer {
      border: 2px solid #0f4c81;
      background: #f0f7ff;
    }

    .chat-link {
      background: #1e293b;
      color: white;
      border-radius: 2rem;
      padding: 0.8rem 1.8rem;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-weight: 500;
    }

    hr {
      margin: 1.2rem 0;
      border: 0.5px solid #e2e8f0;
    }
  </style>
</head>
<body>
<div class="container">
  <!-- 头部校徽展示 -->
  <div class="header">
    <div class="logo-area">
      <i class="fas fa-graduation-cap logo-icon"></i>
      <div class="title"><h1>研途·保研进度追踪</h1></div>
    </div>
    <div class="school-badges" id="schoolBadgesContainer">
      <!-- 动态校徽会在这里渲染 -->
    </div>
  </div>

  <!-- 阶段切换 -->
  <div class="phase-tabs">
    <button class="tab active" data-phase="summer"><i class="fas fa-sun"></i> 夏令营</button>
    <button class="tab" data-phase="pre"><i class="fas fa-leaf"></i> 预推免</button>
    <button class="tab" data-phase="offer"><i class="fas fa-check-circle"></i> Offer接受</button>
    <button class="tab" data-phase="confirm"><i class="fas fa-star"></i> Offer确认</button>
    <button class="tab" data-phase="chat"><i class="fas fa-comments"></i> 对话·信息订阅</button>
  </div>

  <!-- 夏令营面板 -->
  <div id="summerPanel" class="panel active">
    <div class="card" id="summerContainer"></div>
  </div>
  <!-- 预推免面板 -->
  <div id="prePanel" class="panel">
    <div class="card" id="preContainer"></div>
  </div>
  <!-- Offer接受面板 -->
  <div id="offerPanel" class="panel">
    <div class="card" id="offerListContainer"></div>
  </div>
  <!-- Offer确认面板 -->
  <div id="confirmPanel" class="panel">
    <div class="card" id="confirmContainer"></div>
  </div>
  <!-- 对话/信息板块 -->
  <div id="chatPanel" class="panel">
    <div class="card">
      <div class="section-title"><i class="fas fa-robot"></i> 智能信息订阅与对话</div>
      <p><i class="fas fa-bell"></i> 已建立监控：中国人民大学、上海交通大学、西安交通大学。即将扩展北京大学、清华大学等。</p>
      <p><i class="fas fa-search"></i> 系统每日检索名校保研夏令营通知，一旦发布将立即在此提醒。</p>
      <div style="margin-top:1rem; background:#f1f5f9; padding:1rem; border-radius:1rem;">
        <i class="fas fa-link"></i> <strong>关联对话：</strong> 
        <a href="#" class="chat-link" onclick="alert('模拟对话窗口：保研信息助手已连接。')"><i class="fas fa-external-link-alt"></i> 打开保研信息对话</a>
        <p style="margin-top:0.8rem; font-size:0.9rem;">最新动态：人大法学院夏令营通知预计6月发布；上海交大凯原法学院预推免待更新。</p>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    // ---------- 校徽数据 ----------
    const schoolLogos = {
      "中国人民大学": { icon: "fa-university", color: "#8B1A2B" },
      "上海交通大学": { icon: "fa-ship", color: "#9D2235" },
      "西安交通大学": { icon: "fa-building-columns", color: "#004098" },
      "北京大学": { icon: "fa-feather", color: "#94070A" },
      "清华大学": { icon: "fa-trophy", color: "#742886" },
      "浙江大学": { icon: "fa-sun", color: "#1A3E7A" },
      "复旦大学": { icon: "fa-book-open", color: "#003D79" },
      "南京大学": { icon: "fa-mountain", color: "#6B2C91" },
      "厦门大学": { icon: "fa-umbrella-beach", color: "#0A3D6B" },
      "武汉大学": { icon: "fa-crown", color: "#2E5A2E" }
    };

    // 默认学校列表（已建立+未来）
    const establishedSchools = ["中国人民大学", "上海交通大学", "西安交通大学"];
    const futureSchools = ["北京大学", "清华大学", "浙江大学", "复旦大学", "南京大学", "厦门大学"];
    const allSchools = [...establishedSchools, ...futureSchools];

    // 渲染头部校徽
    function renderBadges() {
      const container = document.getElementById('schoolBadgesContainer');
      if (!container) return;
      let html = '';
      allSchools.forEach(school => {
        const logo = schoolLogos[school] || { icon: 'fa-graduation-cap', color: '#475569' };
        html += `<div class="badge"><i class="fas ${logo.icon}" style="color:${logo.color}"></i> ${school}</div>`;
      });
      container.innerHTML = html;
    }
    renderBadges();

    // ---------- 数据存储结构 ----------
    let appData = {
      summer: {
        ddl: [],           // {id, title, date, progressNote}
        materials: [],     // {id, name, done: false}
        results: [],       // {id, school, status: '通过'/'未通过'/'普通营员'/'优秀营员', progressStage: '申请'/'入营'/'普通营员'/'优秀营员'}
        notes: ''
      },
      pre: {
        ddl: [],
        materials: [],
        results: [],
        notes: ''
      },
      offers: [],         // {id, school, detail}
      confirmedOffer: null // 最终选择的offer id
    };

    // 初始化示例数据 (武汉大学默认offer)
    function initData() {
      // 夏令营示例
      appData.summer.ddl = [
        { id: 's1', title: '人大法学院夏令营申请截止', date: '2025-06-15', progressNote: '准备中' }
      ];
      appData.summer.materials = [
        { id: 'sm1', name: '个人陈述', done: false },
        { id: 'sm2', name: '推荐信', done: true }
      ];
      appData.summer.results = [
        { id: 'sr1', school: '中国人民大学', status: '优秀营员', progressStage: '优秀营员' }
      ];
      appData.pre.ddl = [{ id: 'p1', title: '上交预推免报名', date: '2025-09-10', progressNote: '' }];
      appData.pre.materials = [{ id: 'pm1', name: '成绩单', done: false }];
      appData.pre.results = [];
      
      // 默认offer：武汉大学国际法研究所
      if (appData.offers.length === 0) {
        appData.offers.push({ id: 'off1', school: '武汉大学国际法研究所', detail: '国际法专业' });
        appData.confirmedOffer = 'off1';
      }
    }

    // 保存到localStorage
    function saveData() {
      localStorage.setItem('baoyan_tracker_data', JSON.stringify(appData));
    }
    function loadData() {
      const saved = localStorage.getItem('baoyan_tracker_data');
      if (saved) {
        try {
          appData = JSON.parse(saved);
          // 确保结构完整
          if (!appData.summer) appData.summer = { ddl:[], materials:[], results:[], notes:'' };
        } catch(e){}
      } else {
        initData();
      }
    }
    loadData();

    // ---------- 工具函数：进度条颜色与状态 ----------
    function getProgressStageStyle(stage, status) {
      if (status === '未通过' || status === '终止') return { color: 'red', percent: 100, label: '未通过' };
      const stages = ['申请', '入营', '普通营员', '优秀营员'];
      const idx = stages.indexOf(stage);
      if (idx === -1) return { color: 'green', percent: 100 };
      const percent = ((idx+1) / stages.length) * 100;
      return { color: 'green', percent: percent, label: stage };
    }

    // ---------- 渲染函数 ----------
    function renderSummer() {
      renderPhase('summer', 'summerContainer');
    }
    function renderPre() {
      renderPhase('pre', 'preContainer');
    }
    function renderPhase(phaseKey, containerId) {
      const container = document.getElementById(containerId);
      if (!container) return;
      const data = appData[phaseKey];
      let html = '';

      // DDL部分
      html += `<div class="section-title"><i class="fas fa-calendar-alt"></i> DDL时间与进度</div>`;
      html += `<div id="${phaseKey}DdlList">`;
      data.ddl.forEach((item, index) => {
        html += `<div class="ddl-item">
          <div><strong>${item.title}</strong><br><small>📅 ${item.date}</small> <span class="badge">${item.progressNote || '未设置'}</span></div>
          <div><button class="btn btn-danger" onclick="deleteDdl('${phaseKey}', '${item.id}')"><i class="fas fa-trash"></i></button></div>
        </div>`;
      });
      html += `</div>`;
      html += `<button class="btn btn-primary" onclick="addDdl('${phaseKey}')"><i class="fas fa-plus"></i> 添加DDL</button>`;

      // 申请材料
      html += `<div class="section-title" style="margin-top:1.5rem;"><i class="fas fa-clipboard-list"></i> 申请材料</div>`;
      html += `<ul class="checklist" id="${phaseKey}MaterialList">`;
      data.materials.forEach(mat => {
        html += `<li>
          <input type="checkbox" ${mat.done ? 'checked' : ''} onchange="toggleMaterial('${phaseKey}', '${mat.id}', this.checked)">
          <span style="${mat.done ? 'text-decoration:line-through; color:#64748b;' : ''}">${mat.name}</span>
          <button class="btn" onclick="deleteMaterial('${phaseKey}', '${mat.id}')"><i class="fas fa-times"></i></button>
        </li>`;
      });
      html += `</ul>`;
      html += `<button class="btn btn-primary" onclick="addMaterial('${phaseKey}')"><i class="fas fa-plus"></i> 添加材料项</button>`;

      // 结果与进度条
      html += `<div class="section-title" style="margin-top:1.5rem;"><i class="fas fa-flag"></i> 结果与进度</div>`;
      data.results.forEach(res => {
        const style = getProgressStageStyle(res.progressStage, res.status);
        const fillClass = res.status === '未通过' || res.status === '终止' ? 'red' : '';
        html += `<div class="offer-card">
          <div><strong>${res.school}</strong> | 状态: ${res.status}</div>
          <div style="margin:0.5rem 0;">进度: ${style.label}</div>
          <div class="progress-bar-bg"><div class="progress-fill ${fillClass}" style="width:${style.percent}%; background:${style.color};"></div></div>
          <button class="btn" onclick="deleteResult('${phaseKey}', '${res.id}')">删除</button>
        </div>`;
      });
      html += `<button class="btn btn-primary" onclick="addResult('${phaseKey}')"><i class="fas fa-plus"></i> 添加结果</button>`;

      // 备注
      html += `<div style="margin-top:1rem;"><label>备注/细节：</label>
        <textarea rows="2" style="width:100%" onchange="updateNotes('${phaseKey}', this.value)">${data.notes || ''}</textarea></div>`;

      container.innerHTML = html;
    }

    // Offer接受面板
    function renderOffers() {
      const container = document.getElementById('offerListContainer');
      if (!container) return;
      let html = `<div class="section-title"><i class="fas fa-gift"></i> 所有获得的Offer</div>`;
      appData.offers.forEach(offer => {
        html += `<div class="offer-card">
          <strong>${offer.school}</strong> <span>${offer.detail || ''}</span>
          <button class="btn" onclick="deleteOffer('${offer.id}')">删除</button>
        </div>`;
      });
      html += `<button class="btn btn-primary" onclick="addOffer()"><i class="fas fa-plus"></i> 添加Offer</button>`;
      container.innerHTML = html;
    }

    function renderConfirm() {
      const container = document.getElementById('confirmContainer');
      if (!container) return;
      let html = `<div class="section-title"><i class="fas fa-check-double"></i> 最终Offer确认</div>`;
      if (appData.offers.length === 0) {
        html += `<p>暂无Offer，请先在Offer接受板块添加。</p>`;
      } else {
        appData.offers.forEach(offer => {
          const selected = appData.confirmedOffer === offer.id;
          html += `<div class="offer-card ${selected ? 'selected-offer' : ''}">
            <div><strong>${offer.school}</strong> ${offer.detail || ''}</div>
            <button class="btn ${selected ? 'btn-primary' : ''}" onclick="confirmOffer('${offer.id}')">
              ${selected ? '✅ 当前选择' : '选择此Offer'}
            </button>
          </div>`;
        });
      }
      container.innerHTML = html;
    }

    // 全局刷新UI
    function refreshUI() {
      renderSummer();
      renderPre();
      renderOffers();
      renderConfirm();
      saveData();
    }

    // ---------- 增删改操作 ----------
    window.addDdl = function(phase) {
      const title = prompt('DDL标题（例如：北大法学院截止）');
      if (!title) return;
      const date = prompt('截止日期 (YYYY-MM-DD)');
      const note = prompt('进度备注');
      const id = Date.now().toString();
      appData[phase].ddl.push({ id, title, date: date || '', progressNote: note || '' });
      refreshUI();
    };
    window.deleteDdl = function(phase, id) {
      appData[phase].ddl = appData[phase].ddl.filter(d => d.id !== id);
      refreshUI();
    };
    window.addMaterial = function(phase) {
      const name = prompt('材料名称');
      if (!name) return;
      appData[phase].materials.push({ id: Date.now().toString(), name, done: false });
      refreshUI();
    };
    window.toggleMaterial = function(phase, id, checked) {
      const mat = appData[phase].materials.find(m => m.id === id);
      if (mat) mat.done = checked;
      saveData();
    };
    window.deleteMaterial = function(phase, id) {
      appData[phase].materials = appData[phase].materials.filter(m => m.id !== id);
      refreshUI();
    };
    window.addResult = function(phase) {
      const school = prompt('学校名称');
      if (!school) return;
      const status = prompt('结果 (通过/未通过/普通营员/优秀营员)');
      const stage = prompt('当前进度 (申请/入营/普通营员/优秀营员)');
      appData[phase].results.push({
        id: Date.now().toString(),
        school,
        status: status || '申请',
        progressStage: stage || '申请'
      });
      refreshUI();
    };
    window.deleteResult = function(phase, id) {
      appData[phase].results = appData[phase].results.filter(r => r.id !== id);
      refreshUI();
    };
    window.updateNotes = function(phase, value) {
      appData[phase].notes = value;
      saveData();
    };
    window.addOffer = function() {
      const school = prompt('Offer学校/研究所');
      if (!school) return;
      const detail = prompt('专业/细节');
      appData.offers.push({ id: Date.now().toString(), school, detail: detail || '' });
      refreshUI();
    };
    window.deleteOffer = function(id) {
      appData.offers = appData.offers.filter(o => o.id !== id);
      if (appData.confirmedOffer === id) appData.confirmedOffer = null;
      refreshUI();
    };
    window.confirmOffer = function(id) {
      appData.confirmedOffer = id;
      refreshUI();
    };

    // 选项卡切换
    const tabs = document.querySelectorAll('.tab');
    const panels = {
      summer: document.getElementById('summerPanel'),
      pre: document.getElementById('prePanel'),
      offer: document.getElementById('offerPanel'),
      confirm: document.getElementById('confirmPanel'),
      chat: document.getElementById('chatPanel')
    };
    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const phase = this.dataset.phase;
        tabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        Object.values(panels).forEach(p => p.classList.remove('active'));
        if (panels[phase]) panels[phase].classList.add('active');
      });
    });

    // 初始渲染
    refreshUI();
    // 定时模拟信息更新（象征性）
    setInterval(() => {
      console.log('后台监听保研信息中...');
    }, 60000);
  })();
</script>
</body>
</html>
